# VPS public IP (required)
TURN_EXTERNAL_IP=1.2.3.4

# Domain used as TURN realm (can be same as your backend domain)
TURN_REALM=loan-comedy-licenses-talent.trycloudflare.com

# Static credential for FE env
TURN_USERNAME=fedacn_turn_user
TURN_PASSWORD=change_me_strong_password

# TURN listen + relay range (open in firewall)
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

